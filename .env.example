# Browser-safe value. Leave empty to use the accessible fixture map.
NEXT_PUBLIC_KAKAO_MAP_APP_KEY=
SUPRO_KAKAO_SDK_REFERER=http://localhost:3000/

# Server-only values. Never prefix secrets with NEXT_PUBLIC_.
KAKAO_REST_API_KEY=
KAKAO_MOBILITY_REST_API_KEY=
OPENAI_API_KEY=

# Defaults keep the complete demo offline and deterministic.
SUPRO_DATA_MODE=fixture
SUPRO_DATABASE_PATH=.data/sup-ro.sqlite
